<div class="space-y-6 w-full max-w-2xl">
  <div class="w-full">
    <label class="block text-xl font-bold text-gray-700 mb-6">学習ログ一覧</label>

    <div class="bg-white p-6 shadow rounded mb-6">
      <h3 class="text-lg font-semibold text-gray-800 mb-4">検索・フィルタ</h3>

      <%= form_with url: posts_path, method: :get, local: true, class: "space-y-4" do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">キーワード検索</label>
          <%= f.text_field :keyword,
              placeholder: "タイトルから検索...",
              value: @keyword,
              class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">タグ</label>
          <%= f.select :tag_id,
              options_for_select([["すべて", ""]] + @filter_tags.map { |tag| [tag.name, tag.id] }, @tag_id),
              {},
              class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">ユーザー</label>
          <%= f.select :user_id,
              options_for_select([["すべて", ""]] + @users.map { |user| [user.nickname, user.id] }, @user_id),
              {},
              class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">ソート順</label>
          <%= f.select :sort,
              options_for_select([["最新順", ""], ["古い順", "oldest"]], @sort),
              {},
              class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div class="flex gap-3">
          <%= f.submit "検索", class: "flex-1 px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 cursor-pointer" %>
          <%= link_to "リセット", posts_path, class: "flex-1 px-4 py-2 bg-gray-200 text-gray-800 font-medium rounded-md hover:bg-gray-300 text-center" %>
        </div>
      <% end %>
    </div>

    <div class="bg-white p-6 shadow rounded mb-6">
      <h3 class="text-lg font-semibold text-gray-800 mb-4">人気タグ</h3>
      <div class="flex flex-wrap gap-2">
        <% @popular_tags.each do |tag| %>
          <%= link_to tag.name,
              posts_path(tag_id: tag.id),
              class: "inline-block bg-indigo-100 text-indigo-800 px-3 py-1 rounded-full text-sm font-medium hover:bg-indigo-200 transition-colors" %>
        <% end %>
      </div>
    </div>

    <% pagination_params = { keyword: @keyword, user_id: @user_id, tag_id: @tag_id, sort: @sort } %>

    <% if @keyword.present? || @user_id.present? || @tag_id.present? %>
      <p class="text-sm text-gray-600 mb-4">
        検索結果: <strong><%= @posts.total_count %></strong>件
      </p>
    <% else %>
      <p class="text-md text-gray-600 mb-4">
        全投稿数： <strong><%= Post.count %></strong>件
      </p>
    <% end %>

    <% if @posts.any? %>
      <div class="space-y-4 mb-8">
        <% @posts.each do |post| %>
          <div class="bg-white p-6 shadow rounded hover:shadow-lg transition-shadow">
            <div class="flex items-start justify-between border-b border-gray-200 pb-4 mb-4">
              <div class="flex-1">
                <p class="text-lg font-medium text-gray-800">
                  <%= link_to post.title, post_path(post), class: "text-indigo-600 hover:text-indigo-800 hover:underline" %>
                </p>
                <p class="text-sm text-gray-500 mt-2">
                  投稿者: <%= link_to post.user.nickname, user_path(post.user), class: "hover:text-indigo-600 hover:font-bold" %>
                  |
                  投稿日時: <%= l post.created_at, format: :short %>
                </p>
              </div>
            </div>

            <div class="text-sm text-gray-600 line-clamp-3">
              <%= truncate(post.content, length: 150) %>
            </div>

            <div class="mt-4 pt-4 border-t border-gray-200 flex items-center gap-6">
              <%= render "posts/like_button", post: post, user: current_user %>
              <div class="flex items-center gap-4">
                <span class="text-lg">💬</span>
                <span class="text-gray-600 font-medium"><%= post.comments.count %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="flex justify-center items-center gap-2 flex-wrap">
        <% if @posts.first_page? %>
          <span class="px-4 py-2 border border-gray-200 text-gray-300 rounded-lg bg-gray-50 cursor-not-allowed">最初</span>
        <% else %>
          <%= link_to "最初", posts_path(pagination_params.merge(page: 1)), class: "px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-indigo-600 hover:text-white" %>
        <% end %>

        <% if @posts.first_page? %>
          <span class="px-4 py-2 border border-gray-200 text-gray-300 rounded-lg bg-gray-50 cursor-not-allowed">← 前</span>
        <% else %>
          <%= link_to "← 前", posts_path(pagination_params.merge(page: @posts.current_page - 1)), class: "px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-indigo-600 hover:text-white" %>
        <% end %>

        <% start_page = [@posts.current_page - 2, 1].max %>
        <% end_page = [start_page + 6, @posts.total_pages].min %>

        <% (start_page..end_page).each do |page_num| %>
          <% if page_num == @posts.current_page %>
            <span class="px-4 py-2 bg-indigo-600 text-white rounded-lg font-semibold"><%= page_num %></span>
          <% else %>
            <%= link_to page_num, posts_path(pagination_params.merge(page: page_num)), class: "px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-100" %>
          <% end %>
        <% end %>

        <% if @posts.last_page? %>
          <span class="px-4 py-2 border border-gray-200 text-gray-300 rounded-lg bg-gray-50 cursor-not-allowed">次 →</span>
        <% else %>
          <%= link_to "次 →", posts_path(pagination_params.merge(page: @posts.current_page + 1)), class: "px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-indigo-600 hover:text-white" %>
        <% end %>

        <% if @posts.last_page? %>
          <span class="px-4 py-2 border border-gray-200 text-gray-300 rounded-lg bg-gray-50 cursor-not-allowed">最後</span>
        <% else %>
          <%= link_to "最後", posts_path(pagination_params.merge(page: @posts.total_pages)), class: "px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-indigo-600 hover:text-white" %>
        <% end %>
      </div>
    <% else %>
    <div class="bg-blue-50 border border-blue-200 rounded-md p-6 text-center">
      <p class="text-gray-600">
        <% if @keyword.present? || @user_id.present? || @tag_id.present? %>
          該当する投稿はありません
        <% else %>
          投稿がまだありません
        <% end %>
      </p>
    </div>
    <% end %>
  </div>
</div>
