<%= form_with model: post, class: "space-y-6 bg-white p-6 rounded-lg shadow" do |f| %>
  <label class="block text-xl font-bold text-gray-700">
    <%= t('posts.form.title') %>
  </label>

  <% if post.errors.any? %>
    <div id="error_explanation" class="rounded-md bg-red-50 p-4 border border-red-200">
      <h2 class="text-sm font-medium text-red-800 mb-3">
        <span class="font-bold"><%= post.errors.count %></span><%= t('posts.form.errors_message_suffix') %>
      </h2>
      <ul class="mt-2 list-inside list-disc space-y-2 text-sm text-red-700">
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-1">
    <label class="text-gray-700 text-lg"><%= t('posts.form.title_label') %></label>
    <%= f.text_field :title, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 mt-1 py-1 px-2 block w-full sm:text-sm placeholder-gray-400 border border-gray-300 rounded-md", placeholder: "Railsチュートリアル1章を完了" %>
  </div>

  <div
    data-controller="markdown-preview"
    data-markdown-preview-url-value="<%= preview_posts_path %>"
  >
    <div class="mt-1">
      <label class="text-gray-700 text-lg">入力形式</label>
      <div class="mt-2 flex gap-4">
        <label class="flex items-center gap-2">
          <input
            type="radio"
            name="editor_mode"
            value="plain"
            checked
            data-markdown-preview-target="modePlain"
            data-action="change->markdown-preview#toggleMode"
          >
          <span>通常</span>
        </label>

        <label class="flex items-center gap-2">
          <input
            type="radio"
            name="editor_mode"
            value="markdown"
            data-markdown-preview-target="modeMarkdown"
            data-action="change->markdown-preview#toggleMode"
          >
          <span>Markdown</span>
        </label>
      </div>
    </div>

    <div
      data-markdown-preview-target="layout"
      class="grid grid-cols-1 gap-6 mt-4"
    >
      <div>
        <label class="text-gray-700 text-lg"><%= t('posts.form.content_label') %></label>
        <%= f.text_area :content,
            rows: 12,
            placeholder: "環境構築を無事に終えることができた！",
            data: {
              markdown_preview_target: "input",
              action: "input->markdown-preview#render"
            },
            class: "min-h-[320px] shadow-sm focus:ring-indigo-500 focus:border-indigo-500 mt-1 py-2 px-2 block w-full border border-gray-300 rounded-md" %>

        <p class="mt-2 text-sm text-gray-500" data-markdown-preview-target="help">
          通常入力ではそのまま表示されます。Markdownを選ぶと # 見出し や - 箇条書き が使えます。
        </p>
      </div>

      <div data-markdown-preview-target="previewWrapper" class="hidden">
        <label class="text-gray-700 text-lg">プレビュー</label>
        <div
          data-markdown-preview-target="output"
          class="markdown-body mt-1 border border-gray-300 rounded-md min-h-[320px] bg-gray-50"
        >
          <p class="text-gray-400">ここにプレビューが表示されます</p>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-1">
    <label class="text-gray-700 text-lg"><%= t('posts.form.tags_label') %></label>
    <%= f.text_field :tag_list, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 mt-1 py-1 px-2 block w-full sm:text-sm placeholder-gray-400 border border-gray-300 rounded-md", placeholder: "Ruby, Rails, 初心者向け", value: post.tag_list %>
    <p class="mt-2 text-sm text-gray-500"><%= t('posts.form.tags_help') %></p>
  </div>

  <p class="mt-2 text-sm text-gray-500">
    <% if post.new_record? %>
      <%= t('posts.form.new_hint') %>
    <% else %>
      <%= t('posts.form.edit_hint') %>
    <% end %>
  </p>

  <div class="px-4 py-3 text-right sm:px-6">
    <% if post.new_record? %>
      <%= link_to t('posts.form.cancel'), posts_path, class: "inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      <%= f.submit t('posts.form.create'), class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 hover:cursor-pointer" %>
    <% else %>
      <%= link_to t('posts.form.cancel'), post, class: "inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      <%= f.submit t('posts.form.update'), class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 hover:cursor-pointer" %>
    <% end %>
  </div>
<% end %>
